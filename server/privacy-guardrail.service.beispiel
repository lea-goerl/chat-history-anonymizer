# Beispiel-Unit für die Vorstudien-App (FastAPI/Uvicorn).
# Gegenüber der Dummy-App ändern sich nur drei Zeilen:
#   WorkingDirectory, Environment (SUBMISSION_DIR) und ExecStart.
# Die App liegt in ~/web/privacy-guardrail, die venv in ~/web/privacy-guardrail/.venv.

[Unit]
Description=Privacy Guardrail data-donation app
After=network.target

[Service]
User=privacy-guardrail
WorkingDirectory=/home/privacy-guardrail/web/privacy-guardrail
Environment=SUBMISSION_DIR=/home/privacy-guardrail/web/privacy-guardrail/data/submissions
ExecStart=/home/privacy-guardrail/web/privacy-guardrail/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 50000
Restart=on-failure

[Install]
WantedBy=multi-user.target
